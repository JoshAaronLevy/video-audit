{
  "manifestVersion": 5,
  "id": "video-audit-premiere-bridge",
  "name": "Video Audit Premiere Bridge",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "26.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "videoAuditBridgePanel",
      "label": {
        "default": "Video Audit Bridge"
      },
      "minimumSize": {
        "width": 320,
        "height": 420
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 520
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 560
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}
